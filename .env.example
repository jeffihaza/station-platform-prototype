# Copy to .env.local for local development:
#   cp .env.example .env.local
#
# Server-only — never prefix with VITE_.
DJ_PASSWORD=forthelove

# Pusher — used by lib/pusher-server.cjs and api/chat/* routes.
# PUSHER_KEY and PUSHER_CLUSTER are also returned to the browser via GET /api/chat/config.
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=
