# Copy to .env.local for local development:
#   cp .env.example .env.local
#
# Server-only — never prefix with VITE_.
DJ_PASSWORD=forthelove

# Pusher server — used by lib/pusher-server.cjs → pusher.trigger("radio-chat", "new-message", ...)
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=

# Pusher client — baked into the browser bundle at build time.
# VITE_PUSHER_KEY must match PUSHER_KEY. VITE_PUSHER_CLUSTER must match PUSHER_CLUSTER.
VITE_PUSHER_KEY=
VITE_PUSHER_CLUSTER=

# SoundCloud archive — reposts page URL (server-only).
SOUNDCLOUD_PROFILE_URL=https://soundcloud.com/watergunskillpeople/reposts
